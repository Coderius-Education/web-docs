{
  "version": "0.2",
  "language": "en,nl,nl-NL",
  "import": ["@cspell/dict-nl-nl/cspell-ext.json"],
  "dictionaries": [
    "en_US",
    "nl_NL",
    "softwareTerms",
    "html",
    "css",
    "python",
    "node",
    "typescript",
    "bash",
    "html-symbol-entities",
    "fonts",
    "filetypes",
    "companies"
  ],
  "ignorePaths": [
    "node_modules/**",
    "build/**",
    ".docusaurus/**",
    ".cache/**",
    "static/**",
    "coverage/**",
    "**/*.lock",
    "package-lock.json",
    "yarn.lock",
    "pnpm-lock.yaml",
    ".github/**",
    "**/*.svg",
    "**/*.png",
    "**/*.jpg",
    "**/*.jpeg",
    "**/*.gif",
    "**/*.ico",
    "**/*.pdf"
  ],
  "ignoreRegExpList": [
    "/```[\\s\\S]*?```/g",
    "/`[^`]+`/g",
    "/\\bhttps?:\\/\\/\\S+/g",
    "/\\b[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Za-z]{2,}\\b/g",
    "/\\{[^}]+\\}/g",
    "/<[^>]+>/g",
    "/\\b[A-Za-z]+\\.(md|mdx|py|js|ts|jsx|tsx|json|yml|yaml|html|css)\\b/g"
  ],
  "allowCompoundWords": true,
  "words": [
    "Coderius",
    "Docusaurus",
    "MDX",
    "frontmatter",
    "kebab",
    "cheatsheet",
    "cheatsheets",
    "PRIMM",
    "TryButton",
    "CodeRunner",
    "Thonny",
    "pygame",
    "pygbag",
    "DVWA",
    "CTF",
    "Godot",
    "GDScript",
    "FastAPI",
    "scaffolding",
    "kinematic",
    "subagent",
    "subagents",
    "runnable",
    "linter",
    "linters",
    "repo",
    "repos",
    "admonitions",
    "admonition",
    "displayed",
    "metadata",
    "hyperparameter",
    "hyperparameters"
  ],
  "ignoreWords": []
}
